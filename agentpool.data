info:
  docString: true
  label: TeamCity Agents by Pool

data:
  local:
    source: /devops_cloud_native_dbd/jenkins_migration_report/get_teamcity_pool_distribution

views:
  - type: Chart
    library: echarts

settings:
  height: 500
  type: pie
  x: Pool ID
  y: Agents

echarts:
  settings:
    label:
      formatter: /(params) => params.name + ' : ' + parseFloat(params.percent.toFixed(1)) + '%' /
    backgroundColor: '#F6F8FC'
    borderColor: '#8C8D8E'
    borderWidth: 1
    borderRadius: 4
    padding: 5

    tooltip:
      trigger: item
      valueFormatter: /(params) => params /

    legend:
      selectedMode: multiple