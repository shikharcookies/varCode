info:
  docString: true

label: Build Trend by Tribe

description: |
  Monthly TeamCity build trends across tribes.

data:
  local:
    source: /teamcity_inventory_report/get_teamcity_build_trend_by_tribe

views:
  - type: Chart
    library: echarts

    settings:
      height: 500
      type: line

      x: Month

      y:
        - CAR
        - CFM
        - CM
        - DEVOPS
        - DP
        - MAR
        - MM
        - OTHERS
        - RISKCITIZEN

echarts:
  settings:

    title:
      text: "Build Trend by Tribe"

    tooltip:
      trigger: axis

    legend:
      top: 30

    xAxis:
      type: category

    yAxis:
      type: value
      name: Number of Builds